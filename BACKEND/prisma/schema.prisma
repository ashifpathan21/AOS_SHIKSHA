generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AccountType {
  STUDENT
  INSTRUCTOR
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum OTPType {
  RESET
  LOGIN
}

enum QuestionType {
  MCQ
  NUMERICAL
  WRITTEN
}

enum Status {
  PUBLIC
  PRIVATE
  UNLISTED
}

model User {
  id                  Int                  @id @default(autoincrement())
  name                String
  username            String?
  email               String
  password            String?
  accountType         AccountType          @default(STUDENT)
  image               String?
  imageId             String?
  profile             Profile?
  createdCourses      Course[]             @relation("CreatedCourses")
  enrolledCourses     CourseEnrollment[]
  courseProgress      CourseProgress[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  ratingAndReviews    RatingAndReview[]
  socketId            String?
  active              Boolean              @default(false)
  followers           Follow[]             @relation("UserFollowers")
  followings          Follow[]             @relation("UserFollowings")
  posts               Post[]
  comments            Comment[]
  sendReplies         Reply[]              @relation("SentReplies")
  receivedReplies     Reply[]              @relation("ReceivedReplies")
  votes               Vote[]
  likes               Like[]
  questionSubmissions QuestionSubmission[]
}

model Content {
  id     Int    @id @default(autoincrement())
  url    String
  urlId  String
  post   Post?  @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId Int?
}

enum PostStatus {
  PUBLIC
  PROCESSING
  PRIVATE
}

model Post {
  id        Int        @id @default(autoincrement())
  caption   String?
  content   Content[]
  createdBy Int
  status    PostStatus @default(PROCESSING)
  creater   User       @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())
  comments  Comment[]
  likes     Like[]
}

model Like {
  id     Int  @id @default(autoincrement())
  by     User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId Int

  @@unique([postId, userId])
}

model Comment {
  id           Int         @id @default(autoincrement())
  comment      String
  replies      Reply[]
  postId       Int?
  post         Post?       @relation(fields: [postId], references: [id], onDelete: Cascade)
  subsectionId Int?
  subsection   SubSection? @relation(fields: [subsectionId], references: [id], onDelete: Cascade)
  commenterId  Int
  commenter    User        @relation(fields: [commenterId], references: [id], onDelete: Cascade)
  createdAt    DateTime    @default(now())
  edited       Boolean     @default(false)
  updatedAt    DateTime    @updatedAt
  votes        Vote[]
}

model Vote {
  id        Int      @id @default(autoincrement())
  by        User     @relation(fields: [userId], references: [id])
  type      VoteType
  comment   Comment  @relation(fields: [commentId], references: [id])
  userId    Int
  commentId Int
}

enum VoteType {
  UP
  DOWN
}

model Reply {
  id          Int      @id @default(autoincrement())
  reply       String
  to          User     @relation("ReceivedReplies", fields: [userId], references: [id])
  userId      Int
  by          User     @relation("SentReplies", fields: [commenterId], references: [id])
  commenterId Int
  comment     Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  commentId   Int?
  createdAt   DateTime @default(now())
}

model Follow {
  id          Int  @id @default(autoincrement())
  follower    User @relation("UserFollowings", fields: [followerId], references: [id], onDelete: Cascade)
  followerId  Int
  following   User @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)
  followingId Int

  @@unique([followerId, followingId])
}

model Profile {
  id          String    @id @default(uuid())
  gender      Gender?
  dob         DateTime?
  about       String?
  phoneNumber String?
  collegeName String?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      Int       @unique
}

model Course {
  id               Int                @id @default(autoincrement())
  name             String
  description      String
  instructor       User               @relation("CreatedCourses", fields: [userId], references: [id], onDelete: Cascade)
  userId           Int
  outcomes         String[]
  price            Int?
  thumbnail        String
  thumbnailId      String
  category         String
  sections         Section[]
  studentsEnrolled CourseEnrollment[]
  courseProgress   CourseProgress[]
  instructions     String[]
  status           Status
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  ratingAndReviews RatingAndReview[]
}

model RatingAndReview {
  id       Int    @id @default(autoincrement())
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   Int
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId Int
  review   String
  rating   Int

  @@unique([userId, courseId])
}

model CourseEnrollment {
  id        Int      @id @default(autoincrement())
  courseId  Int
  userId    Int
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([courseId, userId])
}

model Section {
  id          Int          @id @default(autoincrement())
  name        String
  subsections SubSection[]
  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId    Int
  test        Test?
}

model SubSection {
  id          Int                    @id @default(autoincrement())
  title       String
  description String?
  videoUrl    String?
  duration    Int?
  points      Int                    @default(2)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  section     Section                @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  sectionId   Int
  completions SubSectionCompletion[]
  questions   Question[]
  comments    Comment[]
}

model CourseProgress {
  id          Int                    @id @default(autoincrement())
  userId      Int
  courseId    Int
  isCompleted Boolean                @default(false)
  user        User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course      Course                 @relation(fields: [courseId], references: [id], onDelete: Cascade)
  completions SubSectionCompletion[]
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@unique([userId, courseId])
}

model SubSectionCompletion {
  id               Int            @id @default(autoincrement())
  courseProgressId Int
  subSectionId     Int
  watchTime        Int            @default(0)
  isFinished       Boolean        @default(false)
  courseProgress   CourseProgress @relation(fields: [courseProgressId], references: [id], onDelete: Cascade)
  subSection       SubSection     @relation(fields: [subSectionId], references: [id], onDelete: Cascade)
  updatedAt        DateTime       @updatedAt

  @@unique([courseProgressId, subSectionId])
}

model OTP {
  id          Int         @id @default(autoincrement())
  otp         String
  type        OTPType
  email       String
  name        String
  password    String
  lastSend    DateTime    @default(now())
  accountType AccountType @default(STUDENT)
  createdAt   DateTime    @default(now())
}

model Question {
  id                  Int                  @id @default(autoincrement())
  question            String
  options             String[]
  correctOption       String
  type                QuestionType
  marks               Int                  @default(4)
  subsectionId        Int?
  subsection          SubSection?          @relation(fields: [subsectionId], references: [id], onDelete: Cascade)
  testId              String?
  test                Test?                @relation(fields: [testId], references: [id], onDelete: Cascade)
  quizId              String?
  quiz                Quiz?                @relation(fields: [quizId], references: [id], onDelete: Cascade)
  createdAt           DateTime             @default(now())
  updateAt            DateTime             @updatedAt
  questionSubmissions QuestionSubmission[]
}

model QuestionSubmission {
  id         Int      @id @default(autoincrement())
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  questionId Int
  isCorrect  Boolean
  by         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     Int
}

model Test {
  id          String     @id @default(uuid())
  title       String
  description String?
  guidelines  String[]
  timeline    Int?
  startTime   DateTime
  endTime     DateTime
  sectionId   Int        @unique
  section     Section    @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  questions   Question[]
  createdAt   DateTime   @default(now())
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

model Quiz {
  id           String     @id @default(uuid())
  title        String
  topic        String
  noOfQuestion Int        @default(5)
  questions    Question[]
  difficulty   Difficulty
  createdAt    DateTime   @default(now())
}
