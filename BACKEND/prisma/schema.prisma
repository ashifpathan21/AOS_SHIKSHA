generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AccountType {
  STUDENT
  INSTRUCTOR
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum OTPType {
  RESET
  LOGIN
}

enum QuestionType {
  MCQ
  NUMERICAL
  WRITTEN
}

enum Status {
  PUBLIC
  PRIVATE
  UNLISTED
}

model User {
  id               Int                @id @default(autoincrement())
  name             String
  username         String?
  email            String
  password         String?
  accountType      AccountType        @default(STUDENT)
  image            String?
  imageId          String?
  profile          Profile?
  createdCourses   Course[]           @relation("CreatedCourses")
  enrolledCourses  CourseEnrollment[]
  courseProgress   CourseProgress[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  ratingAndReviews RatingAndReview[]
  points           BigInt             @default(0)
  socketId         String?
  active           Boolean            @default(false)
  followers        Follow[]           @relation("UserFollowers")
  followings       Follow[]           @relation("UserFollowings")
  posts            Post[]
  comments         Comment[]
}

model Content {
  id     BigInt  @id @default(autoincrement())
  url    String
  urlId  String
  post   Post?   @relation(fields: [postId], references: [id])
  postId BigInt?
}

model Post {
  id        BigInt    @id @default(autoincrement())
  caption   String?
  content   Content[]
  createdBy Int
  creater   User      @relation(fields: [createdBy], references: [id])
  createdAt DateTime  @default(now())
  comments  Comment[]
}

model Comment {
  id           BigInt      @id @default(autoincrement())
  comment      String
  postId       BigInt?
  post         Post?       @relation(fields: [postId], references: [id])
  subsectionId BigInt?
  subsection   SubSection? @relation(fields: [subsectionId], references: [id])
  commenterId  Int
  commenter    User        @relation(fields: [commenterId], references: [id])
  createdAt    DateTime    @default(now())
}

model Follow {
  id          Int  @id @default(autoincrement())
  follower    User @relation("UserFollowings", fields: [followerId], references: [id])
  followerId  Int
  following   User @relation("UserFollowers", fields: [followingId], references: [id])
  followingId Int

  @@unique([followerId, followingId])
}

model Profile {
  id          String    @id @default(uuid())
  gender      Gender?
  dob         DateTime?
  about       String?
  phoneNumber String?
  collegeName String?
  user        User      @relation(fields: [userId], references: [id])
  userId      Int       @unique
}

model Course {
  id               BigInt             @id @default(autoincrement())
  name             String
  description      String
  instructor       User               @relation("CreatedCourses", fields: [userId], references: [id], onDelete: NoAction)
  userId           Int
  outcomes         String[]
  price            BigInt?
  thumbnail        String
  category         String
  sections         Section[]
  studentsEnrolled CourseEnrollment[]
  courseProgress   CourseProgress[]
  instructions     String[]
  status           Status
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  ratingAndReviews RatingAndReview[]
}

model RatingAndReview {
  id       Int    @id @default(autoincrement())
  user     User   @relation(fields: [userId], references: [id])
  userId   Int
  course   Course @relation(fields: [courseId], references: [id])
  courseId BigInt
  review   String
  rating   Int

  @@unique([userId, courseId])
}

model CourseEnrollment {
  id        BigInt   @id @default(autoincrement())
  courseId  BigInt
  userId    Int
  course    Course   @relation(fields: [courseId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([courseId, userId])
}

model Section {
  id          BigInt       @id @default(autoincrement())
  name        String
  subsections SubSection[]
  course      Course?      @relation(fields: [courseId], references: [id])
  courseId    BigInt?
  test        Test?
}

model SubSection {
  id          BigInt                 @id @default(autoincrement())
  title       String
  description String?
  videoUrl    String?
  duration    BigInt?
  points      Int                    @default(2)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  section     Section?               @relation(fields: [sectionId], references: [id])
  sectionId   BigInt?
  completions SubSectionCompletion[]
  questions   Question[]
  comments    Comment[]
}

model CourseProgress {
  id          BigInt                 @id @default(autoincrement())
  userId      Int
  courseId    BigInt
  isCompleted Boolean                @default(false)
  user        User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course      Course                 @relation(fields: [courseId], references: [id], onDelete: Cascade)
  completions SubSectionCompletion[]
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@unique([userId, courseId])
}

model SubSectionCompletion {
  id               BigInt         @id @default(autoincrement())
  courseProgressId BigInt
  subSectionId     BigInt
  watchTime        Int            @default(0)
  isFinished       Boolean        @default(false)
  courseProgress   CourseProgress @relation(fields: [courseProgressId], references: [id], onDelete: Cascade)
  subSection       SubSection     @relation(fields: [subSectionId], references: [id], onDelete: Cascade)
  updatedAt        DateTime       @updatedAt

  @@unique([courseProgressId, subSectionId])
}

model OTP {
  id          Int         @id @default(autoincrement())
  otp         String      
  type        OTPType
  email       String
  name        String
  password    String
  accountType AccountType @default(STUDENT)
  createdAt   DateTime    @default(now())

}

model Question {
  id            BigInt       @id @default(autoincrement())
  question      String
  options       String[]
  correctOption String
  type          QuestionType
  marks         Int          @default(4)
  subsectionId  BigInt?
  subsection    SubSection?  @relation(fields: [subsectionId], references: [id])
  testId        String?
  test          Test?        @relation(fields: [testId], references: [id])
  quizId        String?
  quiz          Quiz?        @relation(fields: [quizId], references: [id])
  createdAt     DateTime     @default(now())
  updateAt      DateTime     @updatedAt
}

model Test {
  id          String     @id @default(uuid())
  title       String
  description String?
  guidlines   String[]
  timeline    Int
  startTime   DateTime
  endTime     DateTime
  sectionId   BigInt     @unique
  section     Section    @relation(fields: [sectionId], references: [id])
  questions   Question[]
  createdAt   DateTime   @default(now())
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

model Quiz {
  id           String     @id @default(uuid())
  title        String
  topic        String
  noOfQuestion Int        @default(5)
  questions    Question[]
  difficulty   Difficulty
  createdAt    DateTime   @default(now())
}
