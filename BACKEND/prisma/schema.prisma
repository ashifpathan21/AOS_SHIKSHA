generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AccountType {
  STUDENT
  INSTRUCTOR
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum Status {
  PUBLIC
  PRIVATE
  UNLISTED
}

model User {
  id               Int                @id @default(autoincrement())
  name             String
  username         String?
  email            String
  password         String
  accountType      AccountType
  image            String
  profile          Profile?
  createdCourses   Course[]           @relation("CreatedCourses")
  enrolledCourses  CourseEnrollment[]
  courseProgress   CourseProgress[]   
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  ratingAndReviews RatingAndReview[]
  points           BigInt             @default(0)
  socketId         String?
  active           Boolean            @default(false)
}

model Profile {
  id          String    @id @default(uuid())
  gender      Gender?
  dob         DateTime?
  about       String?
  phoneNumber String?
  collegeName String?
  user        User      @relation(fields: [userId], references: [id])
  userId      Int       @unique
}

model Course {
  id               BigInt             @id @default(autoincrement())
  name             String
  description      String
  instructor       User               @relation("CreatedCourses", fields: [userId], references: [id], onDelete: NoAction)
  userId           Int
  outcomes         String[]
  price            BigInt?
  thumbnail        String
  category         String
  sections         Section[]
  studentsEnrolled CourseEnrollment[]
  courseProgress   CourseProgress[]  
  instructions     String[]
  status           Status
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  ratingAndReviews RatingAndReview[]
}

model RatingAndReview {
  id       Int    @id @default(autoincrement())
  user     User   @relation(fields: [userId], references: [id])
  userId   Int
  course   Course @relation(fields: [courseId], references: [id])
  courseId BigInt
  review   String
  rating   Int

  @@unique([userId, courseId])
}

model CourseEnrollment {
  id        BigInt   @id @default(autoincrement())
  courseId  BigInt
  userId    Int
  course    Course   @relation(fields: [courseId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([courseId, userId])
}

model Section {
  id          BigInt       @id @default(autoincrement())
  name        String
  subsections SubSection[]
  course      Course?      @relation(fields: [courseId], references: [id])
  courseId    BigInt?
}

model SubSection {
  id          BigInt                 @id @default(autoincrement())
  title       String
  description String?
  videoUrl    String?
  duration    BigInt?
  points      Int                    @default(2)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  section     Section?               @relation(fields: [sectionId], references: [id])
  sectionId   BigInt?
  completions SubSectionCompletion[] 
}

model CourseProgress {
  id          BigInt                 @id @default(autoincrement())
  userId      Int
  courseId    BigInt
  isCompleted Boolean                @default(false)
  user        User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course      Course                 @relation(fields: [courseId], references: [id], onDelete: Cascade)
  completions SubSectionCompletion[]
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  @@unique([userId, courseId]) 
}

model SubSectionCompletion {
  id               BigInt         @id @default(autoincrement())
  courseProgressId BigInt
  subSectionId     BigInt
  watchTime        Int            @default(0) 
  isFinished       Boolean        @default(false) 
  courseProgress   CourseProgress @relation(fields: [courseProgressId], references: [id], onDelete: Cascade)
  subSection       SubSection     @relation(fields: [subSectionId], references: [id], onDelete: Cascade)
  updatedAt        DateTime       @updatedAt

  @@unique([courseProgressId, subSectionId]) 
}
